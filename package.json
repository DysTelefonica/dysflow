{
  "name": "dysflow",
  "version": "2.18.0",
  "description": "Dysflow Access automation product foundation.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "bin": {
    "dysflow": "./dist/cli/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:public": "vitest run -c vitest.public.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e:mcp": "node E2E_testing/mcp-e2e.mjs",
    "test:e2e:mcp:resume": "node E2E_testing/mcp-e2e.mjs --resume",
    "test:e2e:mcp:release": "node E2E_testing/mcp-e2e.mjs --release",
    "test:ps1": "pwsh -Command \"Invoke-Pester scripts/tests/\"",
    "build": "tsc -p tsconfig.json",
    "lint": "node scripts/check-core-adapter-boundary.mjs && node scripts/check-optional-presence-guards.mjs && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && biome check src/ test/ tests/ scripts/ E2E_testing/_helpers/",
    "lint:fix": "biome check src/ test/ tests/ scripts/ E2E_testing/_helpers/ --write",
    "format": "biome format src/ test/ tests/ scripts/ E2E_testing/_helpers/ --write",
    "format:check": "biome format src/ test/ tests/ scripts/ E2E_testing/_helpers/ --check",
    "coverage": "vitest run --coverage",
    "prepare": "pnpm build",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "~20.19.0",
    "@vitest/coverage-v8": "4.1.9",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.28.1": ">=0.28.1",
      "hono@<4.12.25": ">=4.12.25"
    }
  }
}
