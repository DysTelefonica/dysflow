{
  "name": "dysflow",
  "version": "1.2.21",
  "description": "Dysflow Access automation product foundation.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "bin": {
    "dysflow": "./dist/cli/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:e2e:mcp": "node E2E_testing/mcp-e2e.mjs",
    "test:ps1": "pwsh -Command \"Invoke-Pester scripts/tests/\"",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && biome check src/ test/",
    "lint:fix": "biome check src/ test/ --write",
    "format": "biome format src/ test/ --write",
    "format:check": "biome format src/ test/ --check",
    "coverage": "vitest run --coverage",
    "prepare": "pnpm build",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  }
}
