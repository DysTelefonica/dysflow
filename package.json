{
  "name": "dysflow",
  "version": "0.8.0",
  "description": "Dysflow Access automation product foundation.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "bin": {
    "dysflow": "./dist/cli/index.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:ps1": "pwsh -Command \"Invoke-Pester scripts/tests/\"",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit && biome check src/ test/",
    "format": "biome format src/ test/ --write",
    "format:check": "biome format src/ test/ --check",
    "coverage": "vitest run --coverage",
    "prepare": "pnpm build",
    "prepack": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^20.12.12",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
