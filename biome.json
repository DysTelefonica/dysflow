{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**",
      "test/**",
      "scripts/**/*.mjs",
      "E2E_testing/_helpers/**/*.mjs",
      "!!**/dist",
      "!!**/coverage",
      "!!**/node_modules",
      "!!**/scratch",
      "!!E2E_testing/.dysflow/**",
      "!!E2E_testing/.mcp.json",
      "!!E2E_testing/forms/*.form.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noImplicitAnyLet": "warn",
        "noAssignInExpressions": "warn",
        "noTemplateCurlyInString": "warn"
      },
      "style": {
        "noNonNullAssertion": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["E2E_testing/_helpers/mcp-harness.mjs"],
      "linter": {
        "rules": {
          "style": {
            "useTemplate": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/access-smoke-evidence.mjs"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
