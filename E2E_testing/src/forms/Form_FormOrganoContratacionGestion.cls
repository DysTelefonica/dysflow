Option Compare Database
Option Explicit
Private m_OrganoContratacionSeleccionado As OrganoContratacion
Private WithEvents m_FormOrganoContratacion As Form_FormOrganoContratacion
Public Event Eliminar()
Public Event Seleccionar(m_OrganoContratacionSeleccionado As OrganoContratacion)
Private m_Error As String


Private Sub cmdElegir_Click()
    On Error GoTo errores
    m_Error = ""
    If m_OrganoContratacionSeleccionado Is Nothing Then
        Exit Sub
    End If
    RaiseEvent Seleccionar(m_OrganoContratacionSeleccionado)
    DoCmd.Close acForm, Me.Name, acSaveNo
     Exit Sub
errores:
    If Err.Number <> 1000 Then
        m_Error = "Al cmdElegir_Click se ha devuelto el error: " & Err.Number & vbNewLine & "Detalle: " & Err.Description
        On Error Resume Next
        CorreoAlAdministrador m_Error
    End If
    
    DoCmd.Hourglass False
    pregunta = MsgBox(m_Error, vbCritical, "Error")
End Sub

Private Sub cmdSalir_Click()
    On Error Resume Next
    DoCmd.Close acForm, Me.Name, acSaveNo
End Sub


Public Function Filtrar(Optional ByRef p_Error As String) As String
    
    Dim m_Col As Scripting.Dictionary
    Dim m_OrganoContratacion As OrganoContratacion
    Dim m_ID As Variant
    Dim lst As ListBox
   
    On Error GoTo errores
    
    p_Error = ""
    Set m_OrganoContratacionSeleccionado = Nothing
    Me.ComandoEliminar.Enabled = False
    Me.ComandoEditar.Enabled = False
    Set lst = Me.ListaFiltrados
    lst.RowSource = "IDOrganoContratacion;OC;DESCRIPCIÓN"
    
    Avance "Obteniendo los OrganoContrataciones Filtrados"
    Set m_Col = m_ObjEntorno.OrganosContratacion
    If p_Error <> "" Then
        Err.Raise 1000
    End If
    If m_Col Is Nothing Then
        Exit Function
    End If
    
    For Each m_ID In m_Col
        Set m_OrganoContratacion = m_Col(m_ID)
        If Nz(Me.OrganoContratacion, "") <> "" Then
            If InStr(1, m_OrganoContratacion.OrganoContratacion, Me.OrganoContratacion) = 0 Then
                GoTo siguiente
            End If
        End If
        lst.AddItem m_OrganoContratacion.IDOrganoContratacion & ";" & Replace(m_OrganoContratacion.OrganoContratacion, ";", ":") & _
                ";" & Replace(m_OrganoContratacion.DESCRIPCION, ";", ":")
siguiente:
        Set m_OrganoContratacion = Nothing
    Next
    lst.Selected(1) = True
    ListaFiltrados_Click
    Exit Function
errores:
    If Err.Number <> 1000 Then
        p_Error = "El método Filtrar ha producido el error nº: " & Err.Number & vbNewLine & "Detalle: " & Err.Description
    End If
    
End Function

