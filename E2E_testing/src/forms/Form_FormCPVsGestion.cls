Option Compare Database
Option Explicit
Private m_CPVSeleccionado As CPV
Private WithEvents m_FormCPV As Form_FormCPV
Public Event Eliminar()
Public Event Seleccionar(m_CPVSeleccionado As CPV)
Private m_Error As String


Private Sub cmdElegir_Click()
    On Error GoTo errores
    m_Error = ""
    If m_CPVSeleccionado Is Nothing Then
        Exit Sub
    End If
    RaiseEvent Seleccionar(m_CPVSeleccionado)
     Exit Sub
errores:
    If Err.Number <> 1000 Then
        m_Error = "Al cmdElegir_Click se ha devuelto el error: " & Err.Number & vbNewLine & "Detalle: " & Err.Description
        On Error Resume Next
        CorreoAlAdministrador m_Error
    End If
    
    DoCmd.Hourglass False
    pregunta = MsgBox(m_Error, vbCritical, "Error")
End Sub

Private Sub cmdSalir_Click()
    On Error Resume Next
    DoCmd.Close acForm, Me.Name, acSaveNo
End Sub


Public Function Filtrar(Optional ByRef p_Error As String) As String
    
    Dim m_Col As Scripting.Dictionary
    Dim m_CPV As CPV
    Dim m_ID As Variant
    Dim lst As ListBox
   
    On Error GoTo errores
    
    p_Error = ""
    Set m_CPVSeleccionado = Nothing
    Me.ComandoEliminar.Enabled = False
    Me.ComandoEditar.Enabled = False
    Set lst = Me.ListaFiltrados
    lst.RowSource = "IDCPV;CPV"
    
    Avance "Obteniendo los CPVes Filtrados"
    Set m_Col = m_ObjEntorno.CPVs
    If p_Error <> "" Then
        Err.Raise 1000
    End If
    If m_Col Is Nothing Then
        Exit Function
    End If
    
    For Each m_ID In m_Col
        Set m_CPV = m_Col(m_ID)
        If Nz(Me.CPV, "") <> "" Then
            If InStr(1, m_CPV.CPV, Me.CPV) = 0 Then
                GoTo siguiente
            End If
        End If
        lst.AddItem m_CPV.IDCPV & ";" & Replace(m_CPV.CPV, ";", ":")
siguiente:
        Set m_CPV = Nothing
    Next
    lst.Selected(1) = True
    ListaFiltrados_Click
    Exit Function
errores:
    If Err.Number <> 1000 Then
        p_Error = "El método Filtrar ha producido el error nº: " & Err.Number & vbNewLine & "Detalle: " & Err.Description
    End If
    
End Function

